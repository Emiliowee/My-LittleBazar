# Copiá a `.env.local` (misma carpeta del proyecto). Ese archivo no se sube al repo.
# `.env.example` puede subirse a GitHub solo con valores vacíos.

# Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — https://console.groq.com/keys
GROQ_API_KEY=

# Hugging Face — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Opcional: proveedor preferido si tenés varias claves (`gemini` por defecto)
# AI_PROVIDER=groq

# Alias Gemini:
# GOOGLE_API_KEY=
