{
  "name": "my-little-bazar",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently -k -n \"vite,electron\" -c \"cyan,magenta\" \"vite\" \"wait-on http-get://127.0.0.1:5173 && electron .\"",
    "dev:vite": "vite",
    "dev:electron": "electron .",
    "build": "vite build && electron-builder",
    "build:vite": "vite build",
    "test:migrations": "electron scripts/test-migrations.cjs",
    "test:venta": "electron scripts/test-flujo-venta.cjs",
    "test:credito": "electron scripts/test-flujo-credito.cjs",
    "test:saldos": "node scripts/test-saldos-ledger.mjs",
    "test:saldos:store": "electron scripts/test-saldos-store.cjs",
    "test:alta": "node scripts/test-alta-detect.mjs && node scripts/test-alta-parse.mjs && node scripts/test-alta-suggest.mjs && node scripts/test-price-hint.mjs",
    "test:label-rotation": "node scripts/test-label-rotation.cjs",
    "test:devoluciones": "electron scripts/test-devoluciones.cjs",
    "test:cobro": "electron scripts/test-cobro-mixto.cjs",
    "test:escenarios": "electron scripts/test-saldos-escenarios.cjs",
    "test:eliminar-venta": "electron scripts/test-eliminar-venta.cjs",
    "test:compras-cliente": "electron scripts/test-compras-cliente.cjs",
    "test:ajuste-precio": "electron scripts/test-ajuste-precio.cjs",
    "test:vales": "electron scripts/test-vales.cjs",
    "test:banqueta": "electron scripts/test-banqueta.cjs",
    "test:fiado-saldos": "electron scripts/test-fiado-saldos.cjs",
    "test:reportes": "node scripts/test-reportes.mjs",
    "test:reporte-pdf": "node scripts/test-reporte-pdf.mjs",
    "audit:ipc": "node scripts/audit-ipc.cjs",
    "audit:sim": "electron scripts/audit-sim-dia.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@radix-ui/colors": "^3.0.0",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "^12.8.0",
    "bwip-js": "^4.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pdf-to-printer": "^5.6.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.1.0",
    "react-hotkeys-hook": "^5.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.25.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "tailwindcss": "^4.2.2",
    "vite": "^6.3.5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.mylittlebazar.app",
    "productName": "My Little Bazar",
    "copyright": "Copyright © 2026 My Little Bazar",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/bindings/**",
      "**/node_modules/file-uri-to-path/**",
      "**/node_modules/pdf-to-printer/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "My-Little-Bazar-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "My Little Bazar"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png"
    },
    "publish": null
  }
}
